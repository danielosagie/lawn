<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Allow Electron's V8 JIT (required for Electron + hardened runtime). -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <!-- Loaded native modules (e.g. rclone is launched via spawn, not loaded
       in-process, so this stays narrow). Keep enabled until we audit which
       native deps strictly need it. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <!-- Outbound network for S3 + Convex. -->
  <key>com.apple.security.network.client</key>
  <true/>
  <!-- Read user-selected files (settings.json, mount root, etc). -->
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
  <!-- Spawn child processes (rclone, the Resolve bridge). -->
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
</dict>
</plist>
