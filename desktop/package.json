{
  "name": "videoinfra-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop sync companion for lawn — version-folder pull/push to your S3 bucket.",
  "main": "electron-main.cjs",
  "scripts": {
    "dev:renderer": "vite dev --port 5300",
    "dev:electron": "wait-on http://localhost:5300 && electron .",
    "dev": "concurrently -n web,electron -c blue,magenta \"bun run dev:renderer\" \"bun run dev:electron\"",
    "build:renderer": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.991.0",
    "@aws-sdk/lib-storage": "^3.991.0",
    "convex": "^1.31.7",
    "fast-xml-parser": "^5.8.0",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "typescript": "^5",
    "vite": "^7.1.7",
    "wait-on": "^7.2.0"
  }
}
